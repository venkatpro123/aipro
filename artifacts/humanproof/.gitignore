.vercel

# v40.0 security: environment files containing API keys must never be committed.
# .env.example is allowed (template with placeholder values).
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local

# Build artifacts
dist
dist-ssr
build
.cache

# Node modules
node_modules
.pnp
.pnp.js

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.swp
*.swo
Thumbs.db

# Coverage / test
coverage
*.lcov
.nyc_output
playwright-report
test-results

# TypeScript build info
*.tsbuildinfo
.eslintcache

# Local Supabase
supabase/.branches
supabase/.temp
supabase/.env

# Secrets / credentials backup files (catch-all)
*.pem
*.key
*-secret.json
*-credentials.json
