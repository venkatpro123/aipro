  "private": true,
  "description": "Real-time AI intelligence scraper — Crawl4AI + Playwright + BullMQ workers on Fly.io",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
