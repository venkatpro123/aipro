{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && node --env-file=.env ./build-local/index.mjs",
    "build": "node ./build.mjs",
    "vercel-build": "pnpm --filter @workspace/humanproof run build",
    "deploy": "npx wrangler deploy",
    "dev:worker": "npx wrangler dev src/worker.ts",
    "start": "node --enable-source-maps ./build-local/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@supabase/supabase-js": "^2.101.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^4.1.0",
    "serverless-http": "^4.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
