# Real-Time Intelligence Scraper — env vars
# Copy to .env.local for development. Production secrets live in `fly secrets`.

# ── Supabase (writes scrape_jobs, breaking_news_events, live_signals_v2, etc) ──
SUPABASE_URL=https://ysenimczeasmaeojzlkt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                  # service_role JWT — server-side ONLY

# ── BullMQ queue backend ─────────────────────────────────────────────────────
# Upstash Redis free tier (10k cmds/day). Format: rediss://default:pwd@host:port
REDIS_URL=

# ── Inbound HMAC auth (from supabase scraper-enqueue Edge Function) ──────────
# Generate: openssl rand -hex 32
HMAC_SHARED_SECRET=

# ── AI enrichment ────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Meilisearch (Fly.io sister app) ──────────────────────────────────────────
MEILISEARCH_HOST=http://meili.internal:7700
MEILISEARCH_API_KEY=

# ── Per-source API tokens ────────────────────────────────────────────────────
GITHUB_TOKEN=                               # GitHub PAT for repo activity reads
REDDIT_CLIENT_ID=                           # OAuth app credentials
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=humansheild-scraper/0.1 (contact: youcandoitsonevergiveup@gmail.com)

# ── Operational knobs ────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info
QUEUE_CONCURRENCY_HTTP=10                   # parallel HTTP-only jobs
QUEUE_CONCURRENCY_BROWSER=1                 # Chromium = single instance
